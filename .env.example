# ─────────────────────────────────────────────────────────────
# Notarie — 환경변수 예시
# 실제 값은 .env.local 에 작성하세요 (커밋 금지).
# ─────────────────────────────────────────────────────────────

# Notion 내부 인테그레이션 시크릿
# https://www.notion.so/my-integrations 에서 발급 (ntn_... 형식)
NOTION_TOKEN=

# 콘텐츠 data source ID (Notion API 2025-09-03, data_source_id 기준 쿼리)
# 지정 시 우선 사용됩니다. 모르면 비워두고 NOTION_DATABASE_ID 만 설정해도 됩니다.
NOTION_DATA_SOURCE_ID=

# Notion 데이터베이스 ID (NOTION_DATA_SOURCE_ID 미지정 시 이 값으로 data source 자동 조회)
NOTION_DATABASE_ID=

# 온디맨드 재검증(ISR) 웹훅 보호용 시크릿 (임의의 긴 무작위 문자열)
NOTION_REVALIDATE_SECRET=

# 사이트 공개 URL (SEO canonical / OG 메타용, 예: https://notarie.example.com)
NEXT_PUBLIC_SITE_URL=
